# ===== Server =====
PORT=3000
JSON_BODY_LIMIT=15mb
ADMIN_TOKEN_SECRET=         # 留空将基于 cwd 派生
ADMIN_PASSWORD=admin        # 首次启动后请到「系统配置」修改

# ===== MySQL =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=                # 必填：MySQL 密码
DB_NAME=plus_papay
DB_POOL_LIMIT=60

# ===== 浏览器 =====
HEADFUL=0                   # 1 = 有头模式（调试用）
CHROMIUM_CHANNEL=           # 留空使用 Playwright 自带 Chromium；可选 chrome / msedge

# ===== ChatGPT / Stripe（用于创建 Plus 订单的客户端 token，构建时由后端动态注入即可）=====
CHATGPT_TOKEN=
STRIPE_KEY=

# ===== Billing 默认值（可选；不填则全部从「资产池」按任务取卡 / 取手机号 / 取地址）=====
BILLING_COUNTRY=US
BILLING_ADDRESS=
BILLING_CITY=
BILLING_STATE=
BILLING_ZIP=
BILLING_NAME=
BILLING_EMAIL=              # PayPal 注册邮箱，留空则随机生成 @hotmail.com
BILLING_PHONE=
PAYPAL_PASSWORD=

# ===== 银行卡（建议放在「资产池」管理，不要走环境变量）=====
CARD_NUMBER=
CARD_EXPIRY=
CARD_CVC=

# ===== 短信接码 API（接收 PayPal SMS）=====
SMS_API_KEY=

# ===== 代理（强烈建议使用住宅代理，支持 {session} 占位符做 sticky session）=====
# 第一跳系统代理：只用于外部网络出口；localhost / 127.0.0.1 / MySQL 不走代理
SYSTEM_PROXY=
# 示例：http://USER:PASS@your-proxy-host:1000
# 示例：http://USER-session-{session}:PASS@your-proxy-host:1000
# 批量任务代理池第二跳；后台系统配置里可配置多行
PROXY=

# ===== 邮箱通道 =====
# 临时邮箱 Provider：cloudflare_temp_email / freemail
INBOX_PROVIDER=cloudflare_temp_email
# 临时邮箱 API（cloudflare_temp_email 或 idinging/freemail 部署地址）
INBOX_API_BASE=             # 如：https://your-temp-email.example.com
# freemail 私有部署 JWT_TOKEN（公开实例或未开启鉴权可留空）
INBOX_TOKEN=
# 临时邮箱可用域名（多行/逗号分隔）；为空则由后台「系统配置」管理
INBOX_EMAIL_DOMAINS=
# 自定义随机邮箱域名（用于 OpenAI 注册）
RANDOM_EMAIL_DOMAIN=
